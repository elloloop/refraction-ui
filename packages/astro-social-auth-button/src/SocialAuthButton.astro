---
import {
  createSocialAuthButton,
  socialAuthButtonVariants,
  lastUsedBadgeVariants,
  type SocialProvider,
} from '@refraction-ui/social-auth-button'
import { cn } from '@refraction-ui/shared'

interface Props extends astroHTML.JSX.HTMLAttributes {
  provider: SocialProvider
  lastUsed?: boolean
  loading?: boolean
  disabled?: boolean
}

const {
  provider,
  lastUsed,
  loading,
  disabled,
  class: className,
  ...props
} = Astro.props

const { label, mono, dataAttributes } = createSocialAuthButton({ provider })

// Mirrors the react-button outline variant base + outline classes so the Astro
// and React buttons render identically.
const buttonClasses = cn(
  'inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg]:shrink-0',
  'border border-input bg-background shadow-sm hover:bg-accent hover:text-accent-foreground',
  'w-full justify-center gap-2',
  className,
)

const iconFill = (color: string) => (mono ? 'currentColor' : color)
---

<div class={socialAuthButtonVariants()}>
  <button
    type="button"
    class={buttonClasses}
    disabled={disabled || loading}
    {...dataAttributes}
    {...props}
  >
    {loading ? (
      <svg
        class="animate-spin h-4 w-4"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <circle
          class="opacity-25"
          cx="12"
          cy="12"
          r="10"
          stroke="currentColor"
          stroke-width="4"
        />
        <path
          class="opacity-75"
          fill="currentColor"
          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
        />
      </svg>
    ) : (
      <svg
        class="shrink-0"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        {provider === 'google' && (
          <path
            fill={iconFill('#4285F4')}
            d="M21.35 11.1H12v2.92h5.35c-.23 1.4-1.65 4.1-5.35 4.1a5.99 5.99 0 0 1 0-11.98c1.71 0 2.86.73 3.52 1.36l2.4-2.31C16.46 3.7 14.43 2.8 12 2.8a9.2 9.2 0 1 0 0 18.4c5.31 0 8.82-3.73 8.82-8.99 0-.6-.07-1.06-.17-1.51Z"
          />
        )}
        {provider === 'github' && (
          <path
            fill="currentColor"
            d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48l-.01-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.46-1.11-1.46-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.9 1.53 2.36 1.09 2.94.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02a9.6 9.6 0 0 1 5 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.85l-.01 2.74c0 .27.18.58.69.48A10 10 0 0 0 12 2Z"
          />
        )}
        {provider === 'microsoft' && (
          <Fragment>
            <path fill={iconFill('#F25022')} d="M3 3h8v8H3z" />
            <path fill={iconFill('#7FBA00')} d="M13 3h8v8h-8z" />
            <path fill={iconFill('#00A4EF')} d="M3 13h8v8H3z" />
            <path fill={iconFill('#FFB900')} d="M13 13h8v8h-8z" />
          </Fragment>
        )}
        {provider === 'apple' && (
          <path
            fill="currentColor"
            d="M16.37 12.78c-.03-2.62 2.14-3.88 2.24-3.94-1.22-1.79-3.12-2.03-3.79-2.06-1.61-.16-3.15.95-3.97.95-.82 0-2.08-.93-3.42-.9-1.76.03-3.39 1.02-4.29 2.6-1.83 3.18-.47 7.88 1.31 10.46.87 1.26 1.91 2.67 3.27 2.62 1.31-.05 1.81-.85 3.4-.85 1.58 0 2.03.85 3.42.82 1.41-.02 2.31-1.28 3.17-2.55.99-1.46 1.4-2.88 1.42-2.95-.03-.01-2.73-1.05-2.76-4.15M13.9 5.1c.72-.88 1.21-2.09 1.08-3.3-1.04.04-2.3.69-3.04 1.56-.66.77-1.24 2.01-1.09 3.19 1.16.09 2.34-.59 3.05-1.45"
          />
        )}
      </svg>
    )}
    {label}
  </button>
  {lastUsed && <span class={lastUsedBadgeVariants()}>Last used</span>}
</div>
