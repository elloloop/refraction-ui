---
import { cn } from '@refraction-ui/shared'
import { datePickerTriggerStyles } from '@refraction-ui/date-picker'

interface Props extends astroHTML.JSX.HTMLAttributes {
  /** Selected date value (ISO string) */
  value?: string
  /** Minimum selectable date (ISO string) */
  minDate?: string
  /** Maximum selectable date (ISO string) */
  maxDate?: string
  /** Show time selection inputs */
  showTime?: boolean
  /** Date format string (ignored by native input, but kept for interface compatibility) */
  format?: string
  /** Placeholder text */
  placeholder?: string
  /** Whether the picker is disabled */
  disabled?: boolean
}

const {
  value,
  minDate,
  maxDate,
  showTime = false,
  format,
  placeholder,
  disabled = false,
  class: className,
  ...props
} = Astro.props

const sliceLen = showTime ? 16 : 10

// Format to YYYY-MM-DD or YYYY-MM-DDTHH:mm
function formatDateStr(isoStr?: string) {
  if (!isoStr) return undefined
  try {
    const d = new Date(isoStr)
    const offset = d.getTimezoneOffset() * 60000
    const localDate = new Date(d.getTime() - offset)
    return localDate.toISOString().slice(0, sliceLen)
  } catch (e) {
    return undefined
  }
}

const parsedValue = formatDateStr(value)
const parsedMin = formatDateStr(minDate)
const parsedMax = formatDateStr(maxDate)
---

<input
  type={showTime ? "datetime-local" : "date"}
  class={cn(datePickerTriggerStyles, "justify-start text-left font-normal w-[280px]", className)}
  value={parsedValue}
  min={parsedMin}
  max={parsedMax}
  disabled={disabled}
  placeholder={placeholder}
  data-rfr-datepicker
  {...props}
/>

<script>
  document.querySelectorAll<HTMLInputElement>('[data-rfr-datepicker]').forEach((input) => {
    if (input.hasAttribute('data-rfr-datepicker-init')) return
    input.setAttribute('data-rfr-datepicker-init', '')

    input.addEventListener('change', (e) => {
      const target = e.target as HTMLInputElement
      if (target.value) {
        const date = new Date(target.value)
        input.dispatchEvent(new CustomEvent('rfr-date-change', {
          detail: { date, iso: date.toISOString() },
          bubbles: true,
        }))
      }
    })
  })
</script>
