---
import { DEFAULT_CATEGORIES, type CookieCategory } from '@refraction-ui/cookie-consent'
import { cn } from '@refraction-ui/shared'

interface Props {
  categories?: CookieCategory[]
  title?: string
  description?: string
  policyUrl?: string
  policyLabel?: string
  position?: 'bottom' | 'top'
  version?: string
  storageKey?: string
  class?: string
}

const {
  categories = DEFAULT_CATEGORIES,
  title = 'We use cookies',
  description = 'We use cookies to run the site, remember your preferences, and measure traffic. Choose which categories to allow.',
  policyUrl,
  policyLabel = 'Cookie policy',
  position = 'bottom',
  version = '',
  storageKey = 'rfr-cookie-consent',
  class: className,
} = Astro.props
---

<!-- Hidden by default; the script reveals it only when consent is needed (avoids a flash for returning visitors). -->
<div
  data-rfr-cookie-consent
  data-version={version}
  data-storage-key={storageKey}
  hidden
  role="dialog"
  aria-label="Cookie consent"
  class={cn('fixed inset-x-0 z-50 p-4', position === 'bottom' ? 'bottom-0' : 'top-0', className)}
>
  <div class="mx-auto max-w-3xl rounded-xl border border-border bg-background p-4 shadow-lg">
    <h2 class="text-base font-semibold">{title}</h2>
    <p class="mt-1 text-sm text-muted-foreground">{description}</p>
    {policyUrl && (
      <a href={policyUrl} target="_blank" rel="noreferrer" class="mt-1 inline-block text-sm text-muted-foreground underline hover:text-foreground">{policyLabel}</a>
    )}

    <div data-rfr-cc-prompt class="mt-3 flex flex-wrap items-center gap-2">
      <button type="button" data-rfr-cc-accept class="rounded-md bg-primary px-3 py-1.5 text-sm font-medium text-primary-foreground">Accept all</button>
      <button type="button" data-rfr-cc-reject class="rounded-md border border-border px-3 py-1.5 text-sm hover:bg-accent">Reject all</button>
      <button type="button" data-rfr-cc-manage class="ml-auto rounded-md border border-border px-3 py-1.5 text-sm hover:bg-accent">Manage preferences</button>
    </div>

    <div data-rfr-cc-settings hidden class="mt-3 space-y-2">
      {categories.map((cat) => (
        <label class="flex items-start justify-between gap-3 rounded-md border border-border p-3">
          <span class="min-w-0">
            <span class="block text-sm font-medium">{cat.label}{cat.required ? ' (required)' : ''}</span>
            {cat.description && <span class="block text-xs text-muted-foreground">{cat.description}</span>}
          </span>
          <input
            type="checkbox"
            data-rfr-cc-cat={cat.id}
            checked={cat.required}
            disabled={cat.required}
            aria-label={cat.label}
            class="mt-0.5 h-4 w-4"
          />
        </label>
      ))}
      <div class="flex flex-wrap items-center gap-2 pt-1">
        <button type="button" data-rfr-cc-save class="rounded-md bg-primary px-3 py-1.5 text-sm font-medium text-primary-foreground">Save preferences</button>
        <button type="button" data-rfr-cc-accept class="rounded-md border border-border px-3 py-1.5 text-sm hover:bg-accent">Accept all</button>
        <button type="button" data-rfr-cc-back class="ml-auto text-sm text-muted-foreground underline hover:text-foreground">Back</button>
      </div>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-rfr-cookie-consent]').forEach((root) => {
    const key = root.dataset.storageKey || 'rfr-cookie-consent'
    const version = root.dataset.version || ''
    const prompt = root.querySelector<HTMLElement>('[data-rfr-cc-prompt]')!
    const settings = root.querySelector<HTMLElement>('[data-rfr-cc-settings]')!

    const read = () => {
      try {
        const raw = localStorage.getItem(key)
        if (!raw) return null
        const parsed = JSON.parse(raw)
        return parsed.version === version ? parsed : null
      } catch {
        return null
      }
    }

    const persist = (preferences: Record<string, boolean>) => {
      try {
        localStorage.setItem(key, JSON.stringify({ version, preferences }))
      } catch {
        /* ignore */
      }
      root.dispatchEvent(new CustomEvent('rfr:cookie-consent', { detail: preferences, bubbles: true }))
      root.hidden = true
    }

    const collect = (allTrue = false) => {
      const prefs: Record<string, boolean> = {}
      root.querySelectorAll<HTMLInputElement>('[data-rfr-cc-cat]').forEach((el) => {
        const id = el.getAttribute('data-rfr-cc-cat') || ''
        prefs[id] = el.disabled ? true : allTrue ? true : el.checked
      })
      return prefs
    }

    // Show the banner only if consent is missing/outdated.
    if (!read()) root.hidden = false

    root.addEventListener('click', (e) => {
      const t = e.target as HTMLElement
      if (t.closest('[data-rfr-cc-accept]')) return persist(collect(true))
      if (t.closest('[data-rfr-cc-reject]')) {
        const prefs: Record<string, boolean> = {}
        root.querySelectorAll<HTMLInputElement>('[data-rfr-cc-cat]').forEach((el) => {
          prefs[el.getAttribute('data-rfr-cc-cat') || ''] = !!el.disabled
        })
        return persist(prefs)
      }
      if (t.closest('[data-rfr-cc-save]')) return persist(collect())
      if (t.closest('[data-rfr-cc-manage]')) {
        prompt.hidden = true
        settings.hidden = false
        return
      }
      if (t.closest('[data-rfr-cc-back]')) {
        settings.hidden = true
        prompt.hidden = false
      }
    })
  })
</script>
