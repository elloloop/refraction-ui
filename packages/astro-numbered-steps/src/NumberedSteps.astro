---
import {
  createNumberedSteps,
  padOrdinal,
  stepColumns,
  numberedStepsItemClass,
  numberedStepsOrdinalClass,
  numberedStepsTitleClass,
  numberedStepsBodyClass,
  type NumberedStepItem,
} from '@refraction-ui/numbered-steps'
import { cn } from '@refraction-ui/shared'

interface Props extends astroHTML.JSX.HTMLAttributes {
  /** The step items to display (3–5 recommended). */
  items: NumberedStepItem[]
  /**
   * Override the number of grid columns. Defaults to clamping item count to
   * 2–5 via `stepColumns`.
   */
  columns?: number
}

const { items, columns, class: className, ...rest } = Astro.props

const cols = columns ?? stepColumns(items.length)
const gridStyle = `grid-template-columns:repeat(${cols},minmax(0,1fr))`
const { ariaProps, dataAttributes } = createNumberedSteps()
---

<div
  class={cn('grid gap-6', className)}
  style={gridStyle}
  {...ariaProps}
  {...dataAttributes}
  {...rest}
>
  {
    items.map((item, index) => (
      <div role="listitem" class={numberedStepsItemClass}>
        <span class={numberedStepsOrdinalClass}>{padOrdinal(index + 1)}</span>
        <p class={numberedStepsTitleClass}>{item.title}</p>
        <p class={numberedStepsBodyClass}>{item.body}</p>
      </div>
    ))
  }
</div>
