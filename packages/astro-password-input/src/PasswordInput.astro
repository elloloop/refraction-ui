---
import { inputVariants, type InputValidationState } from '@refraction-ui/input'
import {
  createPasswordInput,
  passwordToggleVariants,
} from '@refraction-ui/password-input'
import { cn } from '@refraction-ui/shared'

interface Props extends astroHTML.JSX.HTMLAttributes {
  size?: 'sm' | 'default' | 'lg'
  disabled?: boolean
  readonly?: boolean
  required?: boolean
  validationState?: InputValidationState
  revealLabel?: string
  hideLabel?: string
}

const {
  size,
  class: className,
  disabled,
  readonly,
  required,
  validationState,
  revealLabel = 'Show password',
  hideLabel = 'Hide password',
  ...props
} = Astro.props

// Render masked initially; progressive enhancement toggles it client-side.
const { inputType, toggleLabel, togglePressed } = createPasswordInput({
  revealed: false,
  revealLabel,
  hideLabel,
})

const inputClasses = cn(inputVariants({ size, validationState }), 'pr-10', className)
const ariaInvalid =
  validationState === 'invalid' ? true : validationState === 'valid' ? false : undefined
---

<div class="relative" data-rfr-password-input>
  <input
    type={inputType}
    class={inputClasses}
    disabled={disabled}
    readonly={readonly}
    required={required}
    aria-invalid={ariaInvalid}
    data-rfr-password-field
    {...props}
  />
  <button
    type="button"
    aria-label={toggleLabel}
    aria-pressed={togglePressed}
    class={passwordToggleVariants()}
    data-rfr-password-toggle
    data-reveal-label={revealLabel}
    data-hide-label={hideLabel}
  >
    <svg
      aria-hidden="true"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="size-4"
    >
      <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path>
      <circle cx="12" cy="12" r="3"></circle>
    </svg>
  </button>
</div>

<script>
  document
    .querySelectorAll<HTMLElement>('[data-rfr-password-input]')
    .forEach((root) => {
      const field = root.querySelector<HTMLInputElement>(
        '[data-rfr-password-field]',
      )
      const toggle = root.querySelector<HTMLButtonElement>(
        '[data-rfr-password-toggle]',
      )
      if (!field || !toggle) return

      const revealLabel = toggle.dataset.revealLabel ?? 'Show password'
      const hideLabel = toggle.dataset.hideLabel ?? 'Hide password'

      toggle.addEventListener('click', () => {
        const revealed = field.type === 'text'
        const next = !revealed
        field.type = next ? 'text' : 'password'
        toggle.setAttribute('aria-pressed', String(next))
        toggle.setAttribute('aria-label', next ? hideLabel : revealLabel)
      })
    })
</script>
