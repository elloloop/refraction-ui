{
  "name": "@refraction-ui/composer",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@refraction-ui/conversation": "workspace:*",
    "@refraction-ui/emoji-picker": "workspace:*",
    "@refraction-ui/rich-editor": "workspace:*",
    "@refraction-ui/shared": "workspace:*"
  },
  "devDependencies": {},
  "sideEffects": false,
  "license": "MIT",
  "private": true
}
