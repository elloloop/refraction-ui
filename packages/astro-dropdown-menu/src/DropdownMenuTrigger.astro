---
import { cn } from '@refraction-ui/shared'

interface Props extends astroHTML.JSX.HTMLAttributes {}

const { class: className, ...props } = Astro.props
---

<button
  type="button"
  data-rfr-dropdown-trigger
  aria-haspopup="menu"
  aria-expanded="false"
  class={cn(className)}
  {...props}
>
  <slot />
</button>
