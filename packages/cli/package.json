{
  "name": "@refraction-ui/cli",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Refraction UI command line interface",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "refraction": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "storybook:test": "echo 'Storybook tests not implemented yet'",
    "size:check": "echo 'Size check not implemented yet'",
    "size:analyze": "echo 'Size analysis not implemented yet'",
    "a11y": "echo 'A11y tests not implemented yet'"
  },
  "dependencies": {
    "commander": "10.0.0",
    "cosmiconfig": "8.3.6",
    "js-yaml": "4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.5",
    "@types/node": "20.8.2"
  },
  "keywords": [
    "cli",
    "ui",
    "components",
    "refraction",
    "design-system"
  ],
  "author": "Refraction UI Team",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/elloloop/refraction-ui.git",
    "directory": "packages/cli"
  },
  "homepage": "https://elloloop.github.io/refraction-ui/",
  "engines": {
    "node": ">=20.0.0"
  }
}
