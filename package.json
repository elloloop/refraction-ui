{
  "name": "refraction-ui",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test:coverage": "turbo test:coverage",
    "ci:local": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "generate": "node scripts/generate-package.mjs",
    "e2e": "playwright test",
    "e2e:update": "playwright test --update-snapshots",
    "visual": "lost-pixel",
    "visual:update": "lost-pixel update"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@changesets/get-release-plan": "4.0.15",
    "@playwright/test": "1.59.1",
    "@typescript-eslint/eslint-plugin": "8.38.0",
    "@typescript-eslint/parser": "8.38.0",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "8.57.1",
    "lost-pixel": "3.22.0",
    "tsup": "8.5.1",
    "turbo": "2.5.5",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  },
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "odiff-bin",
      "sharp"
    ],
    "overrides": {
      "form-data": "4.0.4",
      "ajv": "6.14.0",
      "astro": "6.3.1",
      "lost-pixel>axios": "1.16.0",
      "brace-expansion@1": "1.1.14",
      "dompurify": "3.4.2",
      "esbuild": "0.28.0",
      "follow-redirects": "1.16.0",
      "picomatch": "4.0.4",
      "postcss": "8.5.14",
      "glob": "10.5.0",
      "rollup": "4.59.0",
      "flatted": "3.4.2",
      "minimatch": "9.0.7",
      "eslint>minimatch": "3.1.4",
      "protobufjs": "8.0.2",
      "devalue": "5.8.1"
    }
  },
  "version": "0.0.1"
}
